rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE PRODUCCIÓN SEGURAS
    
    // Usuarios: Permitir lectura pública para preview de login, escritura solo autenticada
    match /users/{userId} {
      // Permitir lectura a cualquiera (necesario para preview de login)
      allow read: if true;
      
      // Permitir creación, actualización y eliminación solo a usuarios autenticados
      allow create, update, delete: if request.auth != null;
    }
    
    // Compromisos: Solo usuarios autenticados
    match /commitments/{commitmentId} {
      allow read, write: if request.auth != null;
    }
    
    // Empresas: Solo usuarios autenticados
    match /companies/{companyId} {
      allow read, write: if request.auth != null;
    }
    
    // Pagos: Solo usuarios autenticados
    match /payments/{paymentId} {
      allow read, write: if request.auth != null;
    }
    
    // Logs de actividad: Solo lectura para admins, escritura para usuarios autenticados
    match /activity_logs/{logId} {
      // Solo admins pueden leer logs de auditoría
      allow read: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['ADMIN', 'SUPER_ADMIN'];
      
      // Cualquier usuario autenticado puede escribir logs (para registro de actividades)
      allow create: if request.auth != null;
      
      // No permitir actualización ni eliminación (logs son inmutables)
      allow update, delete: if false;
    }
    
    // Logs de auditoría: Solo usuarios autenticados (mantener compatibilidad)
    match /audit_logs/{logId} {
      allow read, write: if request.auth != null;
    }
    
    // Historial de cambios de salas: Solo usuarios autenticados pueden leer, solo sistema puede escribir
    match /sala_changes/{changeId} {
      // Cualquier usuario autenticado puede leer el historial
      allow read: if request.auth != null;
      
      // Solo usuarios autenticados pueden crear registros de cambios
      allow create: if request.auth != null;
      
      // No permitir actualización ni eliminación (logs son inmutables)
      allow update, delete: if false;
    }
    
    // Salas: Solo usuarios autenticados
    match /salas/{salaId} {
      allow read, write: if request.auth != null;
    }

    // Aliases de sala (fusionar nombres históricos): Solo usuarios autenticados
    match /sala_aliases/{empresaId} {
      allow read, write: if request.auth != null;
    }
    
    // Configuraciones: Solo usuarios autenticados
    match /settings/{settingId} {
      allow read, write: if request.auth != null;
    }
    
    // Notificaciones generales del sistema
    match /notifications/{notificationId} {
      // ✅ SIMPLIFICADO: Permitir lectura a usuarios autenticados
      // (El frontend filtra por uid/userId)
      allow read: if request.auth != null;
      
      // Permitir crear a cualquier usuario autenticado
      allow create: if request.auth != null;
      
      // Permitir actualizar a usuarios autenticados (para marcar como leída)
      allow update: if request.auth != null;
      
      // Permitir eliminar a usuarios autenticados
      allow delete: if request.auth != null;
    }
    
    // Versiones de la app (públicas para verificación de actualizaciones)
    match /appVersions/{platform} {
      // ✅ Lectura pública (necesario para verificar actualizaciones sin login)
      allow read: if true;
      
      // ✅ Solo administradores pueden actualizar versiones
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['ADMIN', 'SUPER_ADMIN'];
    }
    
    // Configuración de la app (públicas para verificación de actualizaciones)
    match /appConfig/{document} {
      // ✅ Lectura pública (necesario para verificar actualizaciones sin login)
      allow read: if true;
      
      // ✅ Escritura pública (para herramientas de actualización sin auth)
      // NOTA: En producción, restringir a solo admins si es necesario
      allow write: if true;
    }
    
    // ========================================
    // 🔐 RBAC: Sistema de Permisos de App Móvil
    // ========================================
    
    // PermissionsApp: Permisos granulares de la app móvil
    match /PermissionsApp/{uid} {
      // Lectura: Solo el propio usuario puede leer sus permisos
      allow read: if request.auth.uid == uid;
      
      // Escritura: Solo SUPERADMIN puede modificar permisos
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.appRole == 'SUPERADMIN';
    }

    // ========================================
    // 📋 SISTEMA DE TAREAS DELEGADAS
    // ========================================
    
    // Tareas delegadas: Validación según participantes y permisos
    match /delegated_tasks/{taskId} {
      // Lectura: Solo usuarios con permiso ver_todas, que sean participantes,
      // o que sean el creador / el asignado (necesario para queries por asignadoA.uid y creadoPor.uid)
      allow read: if request.auth != null && (
        // Tiene permiso para ver todas las tareas
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions['tareas.ver_todas'] == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.tareas == true ||
        // Es el creador de la tarea
        resource.data.creadoPor.uid == request.auth.uid ||
        // Es el asignado de la tarea
        resource.data.asignadoA.uid == request.auth.uid ||
        // O está en el array participantes (compatibilidad con documentos nuevos)
        (resource.data.participantes != null && request.auth.uid in resource.data.participantes)
      );
      
      // Creación: Solo usuarios con permiso tareas o tareas.crear
      allow create: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.tareas == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions['tareas.crear'] == true
      );
      
      // Actualización: Solo creador, asignado o usuarios con permiso tareas
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.tareas == true ||
        resource.data.creadoPor.uid == request.auth.uid ||
        resource.data.asignadoA.uid == request.auth.uid
      );
      
      // Eliminación: Solo creador o usuarios con permiso tareas
      allow delete: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.tareas == true ||
        resource.data.creadoPor.uid == request.auth.uid
      );
      
      // Subcollection: Logs de progreso de tareas
      match /progressLogs/{logId} {
        // Lectura: Creador, asignado, participantes o usuarios con permiso tareas
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.tareas == true ||
          get(/databases/$(database)/documents/delegated_tasks/$(taskId)).data.creadoPor.uid == request.auth.uid ||
          get(/databases/$(database)/documents/delegated_tasks/$(taskId)).data.asignadoA.uid == request.auth.uid ||
          (get(/databases/$(database)/documents/delegated_tasks/$(taskId)).data.participantes != null &&
           request.auth.uid in get(/databases/$(database)/documents/delegated_tasks/$(taskId)).data.participantes)
        );
        
        // Creación: Solo el usuario asignado a la tarea
        allow create: if request.auth != null && 
          get(/databases/$(database)/documents/delegated_tasks/$(taskId)).data.asignadoA.uid == request.auth.uid;
        
        // Actualización: Solo el creador del log
        allow update: if request.auth != null && 
          resource.data.usuario.uid == request.auth.uid;
        
        // Eliminación: Solo el creador del log
        allow delete: if request.auth != null && 
          resource.data.usuario.uid == request.auth.uid;
      }
    }

    // ========================================
    // 🔐 COLECCIONES EXPLÍCITAS (antes en catch-all)
    // ========================================

    // Sesiones activas: Tracking de sesiones de usuario
    match /activeSessions/{sessionId} {
      allow read, write: if request.auth != null;
    }

    // Alertas del sistema
    match /alerts/{alertId} {
      allow read, write: if request.auth != null;
    }

    // Configuración de alertas: Solo el propietario
    match /alertsConfig/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Asistencias: Registro de jornada laboral (app móvil)
    match /asistencias/{docId} {
      allow read, write: if request.auth != null;
    }

    // Eventos de calendario
    match /calendar_events/{eventId} {
      allow read, write: if request.auth != null;
    }

    // Empleados
    match /empleados/{docId} {
      allow read, write: if request.auth != null;
    }

    // Ingresos (nombre legacy)
    match /income/{docId} {
      allow read, write: if request.auth != null;
    }

    // Ingresos
    match /incomes/{docId} {
      allow read, write: if request.auth != null;
    }

    // Liquidaciones
    match /liquidaciones/{docId} {
      allow read, write: if request.auth != null;
    }

    // Liquidaciones por sala (snake_case)
    match /liquidaciones_por_sala/{docId} {
      allow read, write: if request.auth != null;
    }

    // Liquidaciones por sala (camelCase legacy)
    match /liquidacionesPorSala/{docId} {
      allow read, write: if request.auth != null;
    }

    // Máquinas en cero: Datos pre-computados por empresa
    match /maquinas_en_cero/{docId} {
      allow read, write: if request.auth != null;
    }

    // Historial de login: Inmutable (solo crear)
    match /loginHistory/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Notas
    match /notes/{noteId} {
      allow read, write: if request.auth != null;
    }

    // Novedades (app móvil)
    match /novedades/{docId} {
      allow read, write: if request.auth != null;
    }

    // Usuarios pendientes de autorización: Solo admins
    match /pending_auth_users/{docId} {
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['ADMIN', 'SUPER_ADMIN'];
    }

    // Métricas de rendimiento del sistema
    match /performanceMetrics/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Cuentas personales/bancarias
    match /personal_accounts/{docId} {
      allow read, write: if request.auth != null;
    }

    // Proveedores
    match /providers/{docId} {
      allow read, write: if request.auth != null;
    }

    // Solicitudes (RRHH)
    match /solicitudes/{docId} {
      allow read, write: if request.auth != null;
    }

    // Nómina: Liquidaciones de nómina mensual
    match /nomina/{docId} {
      allow read, write: if request.auth != null;
    }

    // Configuración de nómina: SMMLV, aux. transporte por año
    match /configuracion_nomina/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['ADMIN', 'SUPER_ADMIN'];
    }

    // Logs del sistema: Inmutables
    match /systemLogs/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Tareas (sistema simple de tareas)
    match /tasks/{taskId} {
      allow read, write: if request.auth != null;
      
      // Subcollection: Logs de progreso
      match /progressLogs/{logId} {
        allow read, write: if request.auth != null;
      }
    }

    // Configuración de usuario: Solo el propietario
    match /userSettings/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      
      // Subcollection: Taskbar favorites
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ========================================
    // Configuración de perfil de usuario
    // ========================================
    match /userProfileSettings/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ========================================
    // Configuración global del sistema (SMMLV, etc.)
    // ========================================
    match /system_config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Solo admins en la práctica (validado en frontend)
    }

    // Subcollection settings de usuarios (preferencias de notificaciones, etc.)
    // Read: cualquier autenticado (necesario para notifyAdminsWorkEvent que lee prefs de todos)
    // Write: solo el dueño
    match /users/{userId}/settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Device tokens para push notifications (cada usuario escribe su propio token)
    match /deviceTokens/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ========================================
    // 🚫 DENY-ALL: Cualquier colección no listada
    // ========================================

    // Estadísticas pre-calculadas del sistema (escriben solo Cloud Functions via Admin SDK)
    match /system_stats/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // Solo Cloud Functions (Admin SDK bypassa rules)
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}